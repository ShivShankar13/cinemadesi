# Copy this file to `.env` (same directory as docker-compose.yml on the VPS)
# and fill in real values. Never commit the real `.env`.

# ── Where the image lives ───────────────────────────────────────────────
# Your GitHub username/org, lowercased. The CI pipeline pushes images here.
GITHUB_OWNER=your-github-username

# Pin a specific commit SHA for stability; defaults to `latest`.
API_TAG=latest

# ── Database ─────────────────────────────────────────────────────────────
# Default uses the `db` service in docker-compose. To use Supabase:
#   1. comment out the `db:` block in docker-compose.yml
#   2. set DATABASE_URL to your Supabase Session-mode pooler URL
#      (Settings → Database → Connection string → JDBC)
DATABASE_URL=jdbc:postgresql://db:5432/cinemadesi
DB_USERNAME=cinemadesi
DB_PASSWORD=change-me-to-a-long-random-string

# ── Auth ────────────────────────────────────────────────────────────────
# >= 32 bytes for HS256. Generate with: openssl rand -base64 32
JWT_SECRET=change-me

# Google OAuth client ID (used only for token audience verification — no secret).
# Leave blank to skip audience check (dev-only).
GOOGLE_CLIENT_ID=

# ── External services ───────────────────────────────────────────────────
# TMDB v3 API key (short string, not the v4 read access token)
TMDB_API_KEY=

# ── App URLs ────────────────────────────────────────────────────────────
# The deployed frontend URL — used in the password-reset email links.
FRONTEND_BASE_URL=https://your-domain.com
# Comma-separated. Include every origin that hits the API.
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Mail (Gmail SMTP) ───────────────────────────────────────────────────
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=your-16-char-app-password-no-spaces
MAIL_FROM=youremail@gmail.com
MAIL_FROM_NAME=CinemaDesi
